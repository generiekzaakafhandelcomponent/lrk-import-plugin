    {
      "parameters": {
        "jsCode": "const item = items[0];\n\nif (!item.binary?.data?.data) {\n  throw new Error('Still no base64 data. Value: ' + JSON.stringify(item.binary?.data?.data));\n}\n\nconst buffer = Buffer.from(item.binary.data.data, 'base64');\nconst csvText = buffer.toString('latin1').replace(/^\\uFEFF/, '');\n\nconst lines = csvText.split('\\n').filter(l => l.trim() !== '');\nconst headers = lines[0].split(';').map(h => h.trim());\n\nreturn lines.slice(1).map(line => {\n  const values = line.split(';');\n  const row = {};\n  headers.forEach((header, i) => {\n    row[header] = (values[i] || '').trim();\n  });\n  return { json: row };\n});"
      },
