      "id": "2ddcdc76-40f2-4c97-a7f2-1c22ac7fd8ba",
      "name": "Set target cbs_codes1",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        -5968,
        -1216
      ]
    },
    {
      "parameters": {
        "jsCode": "const targetCodes = $('Set target cbs_codes1').first().json.target_cbs_codes\n  .map(c => String(c).trim());\n\nreturn $input.all().filter(item => {\n  const code = String(item.json['cbs_code'] || '').trim();\n  return targetCodes.includes(code);\n});"
      },
      "id": "7b3ea4c2-92ac-448c-b7d0-29d8cda1c496",
      "name": "Filter on cbs_codes1",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -5296,
        -1216
      ]
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all();\n\nconst houderMap = new Map();\nconst voorzieningItems = [];\n\nfor (const item of rows) {\n  const row = item.json;\n\n  const type_oko = (row['type_oko'] || '').trim();\n  const kvk_raw  = (row['kvk_nummer_houder'] || '').trim();\n  const lrk_id   = (row['lrk_id'] || '').trim();\n\n  // Compute houder_id\n  let houder_id;\n  if (type_oko === 'VGO' && kvk_raw === '') {\n    houder_id = lrk_id;\n  } else {\n    houder_id = kvk_raw;\n  }\n\n  // Deduplicate houders - first occurrence wins\n  if (!houderMap.has(houder_id)) {\n    houderMap.set(houder_id, {\n      id_str:                     houder_id,\n      naam:                       (row['naam_houder'] || '').trim(),\n      kvk:                        kvk_raw !== '' ? Number(kvk_raw) : null,\n      contact_persoon:            (row['contact_persoon'] || '').replace(/^'+|'+$/g, '').trim(),\n      contact_telefoon:           (row['contact_telefoon'] || '').replace(/^'+|'+$/g, '').trim(),\n      contact_emailadres:         (row['contact_emailadres'] || '').replace(/^'+|'+$/g, '').trim(),\n      contact_website:            (row['contact_website'] || '').replace(/^'+|'+$/g, '').trim(),\n      correspondentie_adres:      (row['correspondentie_adres'] || '').trim(),\n      correspondentie_postcode:   (row['correspondentie_postcode'] || '').trim(),\n      correspondentie_woonplaats: (row['correspondentie_woonplaats'] || '').trim()\n    });\n  }\n\n  // Build voorziening row\n  voorzieningItems.push({\n    lrk_id,\n    houder_id_str:              houder_id,\n    adres:                      (row['opvanglocatie_adres'] || '').trim(),\n    plaats:                     (row['opvanglocatie_woonplaats'] || '').trim(),\n    postcode:                   (row['opvanglocatie_postcode'] || '').trim(),\n    verantwoordelijke_gemeente: (row['verantwoordelijke_gemeente'] || '').trim(),\n    gemeente_cbs_code:          (row['cbs_code'] || '').trim(),\n    soort:                      type_oko\n  });\n}\n\nreturn [{\n  json: {\n    houders:      Array.from(houderMap.values()),\n    voorzienings: voorzieningItems\n  }\n}];"
      },
      "id": "81b9fba3-210c-445b-b766-2fa376fce173",
      "name": "Compute houder_id + deduplicate + split1",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
